{
    // --- Editor Appearance & Behavior ---
    "editor.fontFamily": "'Monaspace Neon Frozen', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 16,
    "editor.mouseWheelZoom": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.suggestSelection": "first",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,

    // Minimap Configuration
    "editor.minimap.enabled": true,
    "workbench.editor.enablePreview": false,
    "workbench.list.openMode": "doubleClick",
    "editor.minimap.maxColumn": 50,
    "editor.minimap.renderCharacters": true,

    // --- Workbench Theme & UI ---
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.iconTheme": "catppuccin-mocha",
    "window.zoomLevel": 1.5,

    // Custom UI Colors (Git status and file list highlights)
    "workbench.colorCustomizations": {
        "gitDecoration.modifiedResourceForeground": "#75beff",
        "gitDecoration.untrackedResourceForeground": "#fab9b9",
        "gitDecoration.addedResourceForeground": "#7cca8a",
        "gitDecoration.ignoredResourceForeground": "#616161",
        "list.errorForeground": "#ef094a",
        "list.warningForeground": "#f38946",
        "editorInlayHint.foreground": "#888888", // Optional: make them subtle
        "editorInlayHint.background": "#00000000" // Optional: transparent background
    },

    // --- Files & Search Exclusions ---
    "files.autoSave": "onFocusChange",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "search.useIgnoreFiles": true,

    // Exclude patterns for Explorer, Search, and File Watching
    "files.exclude": {
        "**/.idea": true,
        "**/.phpunit.cache": true,
        "**/.php-cs-fixer.cache": true
    },
    "search.exclude": {
        "**/.phpunit.cache": true,
        "**/var": true,
        "**/vendor": true,
        "**/*.onnx": true
    },
    "files.watcherExclude": {
        "**/var/**": true,
        "**/vendor/**": true,
        "**/.phpunit.cache/**": true,
        "**/*.onnx": true
    },

    // --- PHP Tooling ---

    // PHP CS Fixer (Code Formatting) - Runs via Docker
    "php-cs-fixer.executablePath": "${workspaceFolder}/.vscode/php-cs-fixer-docker.sh",
    "php-cs-fixer.config": ".php-cs-fixer.dist.php",
    "php-cs-fixer.onsave": true,
    "php-cs-fixer.allowRisky": true,
    "php-cs-fixer.documentFormattingProvider": true,

    // PHPStan (Static Analysis) - Runs via Docker
    // Using binCommand for Docker exec instead of binPath + dockerContainerName
    // This fixes the "Unhandled method phpstan.configResolve" error
    "phpstan.enabled": true,
    "phpstan.binCommand": ["${workspaceFolder}/.vscode/phpstan-docker.sh"],
    "phpstan.configFile": "phpstan.dist.neon",
    "phpstan.showTypeOnHover": false,
    "phpstan.enableStatusBar": true,
    "phpstan.paths": {
        "${workspaceFolder}": "/app"
    },

    // Intelephense & PHP Language Features
    "php.validate.enable": false,
    "php.suggest.basic": false,
    "intelephense.telemetry.enabled": false,
    "intelephense.completion.triggerParameterHints": true,
    "intelephense.format.enable": false,
    "intelephense.environment.includePaths": ["vendor"],

    // --- Language-Specific Overrides ---

    "[php]": {
        "editor.defaultFormatter": "junstyle.php-cs-fixer",
        "editor.formatOnSave": true
    },
    // --- Markdown ---
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "markdown.preview.fontSize": 18,
    "workbench.editorAssociations": {
        "*.md": "default"
    },

    "[yaml]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },

    "files.associations": {
        "*.html": "twig",
        "*.css": "tailwindcss"
    },
    "emmet.includeLanguages": {
        "twig": "html"
    },
    "tailwindCSS.includeLanguages": {
        "plaintext": "html"
    },

    // --- Git ---
    "git.blame.statusBarItem.enabled": true,
    "git.autofetch": true,

    "explorer.confirmDelete": false,

    // --- Error Lens ---
    "errorLens.messageEnabled": true,
    "errorLens.problemRangeDecorationEnabled": true,

    "editor.inlayHints.enabled": "on",
    "editor.inlayHints.fontSize": 11,
    "editor.inlayHints.fontFamily": "Monaspace Neon Frozen Italic",
    "editor.inlayHints.padding": true
}
