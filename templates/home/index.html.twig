{% extends 'base.html.twig' %}

{% block title %}Symfony Web Template{% endblock %}

{% block body %}
    <div class="flex min-h-screen flex-col bg-[#0a0a0a]">
        {# ── Navbar ─────────────────────────────────────────────── #}
        <nav class="border-b border-[#222] bg-[#0a0a0a]">
            <div class="mx-auto flex w-full max-w-[1200px] items-center justify-between px-6 py-4 lg:px-8 xl:max-w-[1200px]">
                <a href="{{ path('app_home') }}" class="text-lg font-bold tracking-tight text-white no-underline">symftemp</a>
                <div class="flex items-center gap-6">
                    <a href="#features" class="text-sm text-gray-400 no-underline transition-colors hover:text-white">Features</a>
                    <a href="#stack" class="text-sm text-gray-400 no-underline transition-colors hover:text-white">Stack</a>
                    <a href="#cta" class="text-sm text-gray-400 no-underline transition-colors hover:text-white">Get started</a>
                    <a href="https://github.com/ineersa/symfony-web-template" target="_blank" rel="noopener noreferrer"
                       class="border border-[#444] bg-transparent px-3 py-1.5 text-xs text-gray-400 no-underline transition-colors hover:border-gray-500 hover:text-white">
                        GitHub
                    </a>
                </div>
            </div>
        </nav>

        {# ── Main ───────────────────────────────────────────────── #}
        <main class="flex-1">
            <div class="mx-auto flex w-full max-w-[1200px] flex-col gap-12 px-6 py-10 lg:max-w-[1040px] lg:px-8 lg:py-14 xl:max-w-[1200px]">

                {# ── Hero ────────────────────────────────────────── #}
                <header class="mt-8 w-full text-center lg:mt-[8vh]">
                    <h1 class="m-0 text-[clamp(2rem,5vw,3.75rem)] tracking-tight text-white">
                        Symfony Web Template
                    </h1>
                    <p class="mx-auto mt-4 max-w-[560px] text-base leading-7 text-gray-400 sm:text-lg">
                        A production-ready starter with Docker, FrankenPHP, Tailwind CSS, and AI tooling integration. Ship faster, skip the boilerplate.
                    </p>
                    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
                        <a href="#cta"
                           class="inline-flex items-center gap-2 bg-white px-5 py-3 text-sm font-semibold text-black no-underline transition-colors hover:bg-gray-200">
                            Get started
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                            </svg>
                        </a>
                        <a href="#features"
                           class="inline-flex items-center border border-[#444] bg-transparent px-5 py-3 text-sm text-gray-300 no-underline transition-colors hover:border-gray-500 hover:text-white">
                            Learn more
                        </a>
                    </div>
                </header>

                {# ── Feature Cards ───────────────────────────────── #}
                <section id="features" class="grid w-full gap-4 text-sm text-gray-300 lg:grid-cols-3">
                    <article class="border border-[#222] bg-[#101010] p-5 shadow-[0_18px_54px_rgba(0,0,0,0.35)]">
                        <div class="mb-4 flex h-9 w-9 items-center justify-center border border-[#333] bg-[#1a1a1a]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
                            </svg>
                        </div>
                        <h2 class="m-0 text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">Docker First</h2>
                        <p class="mt-3 mb-0 leading-7">
                            FrankenPHP with Symfony worker mode, SQLite, Mercure — all containerized. One command to spin up the full stack.
                        </p>
                    </article>

                    <article class="border border-[#222] bg-[#101010] p-5 shadow-[0_18px_54px_rgba(0,0,0,0.35)]">
                        <div class="mb-4 flex h-9 w-9 items-center justify-center border border-[#333] bg-[#1a1a1a]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
                            </svg>
                        </div>
                        <h2 class="m-0 text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">Modern Frontend</h2>
                        <p class="mt-3 mb-0 leading-7">
                            Tailwind CSS, AssetMapper, Stimulus, Turbo, Twig Components, and Live Components — pick the right UX tool for each job.
                        </p>
                    </article>

                    <article class="border border-[#222] bg-[#101010] p-5 shadow-[0_18px_54px_rgba(0,0,0,0.35)]">
                        <div class="mb-4 flex h-9 w-9 items-center justify-center border border-[#333] bg-[#1a1a1a]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
                            </svg>
                        </div>
                        <h2 class="m-0 text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">AI-Ready</h2>
                        <p class="mt-3 mb-0 leading-7">
                            Agent prompts, Mate tools, Castor tasks, and Vera MCP integration. Designed for LLM-assisted development out of the box.
                        </p>
                    </article>
                </section>

                {# ── Tech Stack Grid ─────────────────────────────── #}
                <section id="stack" class="w-full">
                    <h2 class="mb-6 text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">Tech Stack</h2>
                    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
                        {% set techs = [
                            {name: 'PHP 8.5',        tag: 'runtime'},
                            {name: 'FrankenPHP',      tag: 'server'},
                            {name: 'Symfony 7',       tag: 'framework'},
                            {name: 'SQLite',          tag: 'database'},
                            {name: 'Tailwind CSS',    tag: 'styling'},
                            {name: 'Stimulus',        tag: 'frontend'},
                            {name: 'Turbo',           tag: 'frontend'},
                            {name: 'Mercure',         tag: 'real-time'},
                            {name: 'Castor',          tag: 'task-runner'},
                            {name: 'PHPStan',         tag: 'static-analysis'},
                            {name: 'PHPUnit',         tag: 'testing'},
                            {name: 'Docker',          tag: 'infra'},
                        ] %}
                        {% for tech in techs %}
                            <div class="flex items-center gap-2.5 border border-[#222] bg-[#101010] px-4 py-3">
                                <span class="text-sm text-white">{{ tech.name }}</span>
                                <span class="ml-auto rounded border border-[#333] bg-[#1a1a1a] px-1.5 py-0.5 font-mono text-[10px] text-gray-500">{{ tech.tag }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </section>

                {# ── Quick Start / Code Block ────────────────────── #}
                <section id="cta" class="w-full">
                    <h2 class="mb-6 text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">Quick Start</h2>
                    <div class="overflow-hidden border border-[#222] bg-[#101010] shadow-[0_18px_54px_rgba(0,0,0,0.35)]">
                        <div class="flex items-center border-b border-[#333] px-4 py-2">
                            <span class="font-mono text-xs text-gray-500">terminal</span>
                        </div>
                        <pre class="m-0 overflow-x-auto p-4 font-mono text-sm leading-7 text-gray-300"><code><span class="text-gray-500"># Clone and enter the project</span>
git clone https://github.com/ineersa/symfony-web-template.git
cd symfony-web-template

<span class="text-gray-500"># Spin up the stack</span>
castor dev:setup
castor dev:up

<span class="text-gray-500"># Open in browser</span>
open https://localhost</code></pre>
                    </div>
                </section>
            </div>
        </main>

        {# ── Footer ─────────────────────────────────────────────── #}
        <footer class="border-t border-[#222] bg-[#0a0a0a] py-6">
            <div class="mx-auto flex w-full max-w-[1200px] flex-col items-center px-6 lg:max-w-[1040px] lg:px-8 xl:max-w-[1200px]">
                <div class="mb-3 flex space-x-4">
                    <a class="text-sm text-gray-500 transition hover:text-gray-300" target="_blank" rel="noopener noreferrer" href="mailto:ineersa.c@gmail.com">
                        <span class="sr-only">mail</span>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="h-6 w-6 fill-current text-gray-400 transition-colors hover:text-white">
                            <title>Mail</title>
                            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                        </svg>
                    </a>
                    <a class="text-sm text-gray-500 transition hover:text-gray-300" target="_blank" rel="noopener noreferrer" href="https://github.com/ineersa">
                        <span class="sr-only">github</span>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6 fill-current text-gray-400 transition-colors hover:text-white">
                            <title>Github</title>
                            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                        </svg>
                    </a>
                    <a class="text-sm text-gray-500 transition hover:text-gray-300" target="_blank" rel="noopener noreferrer" href="https://www.linkedin.com/in/illia-vasylevskyi-b7353558/">
                        <span class="sr-only">linkedin</span>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6 fill-current text-gray-400 transition-colors hover:text-white">
                            <title>Linkedin</title>
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                    </a>
                </div>
                <div class="mb-2 flex space-x-2 text-sm text-gray-500">
                    <div>Illia Vasylevskyi</div>
                    <div>•</div>
                    <div>© {{ "now"|date("Y") }}</div>
                    <div>•</div>
                    <a href="{{ path('app_home') }}" class="hover:text-gray-300">symftemp</a>
                </div>
            </div>
        </footer>
    </div>
{% endblock %}
