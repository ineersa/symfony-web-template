{% extends 'base.html.twig' %}

{% block title %}Symfony Web Template{% endblock %}

{% block body %}
    <main style="max-width: 760px; margin: 3rem auto; padding: 0 1rem; font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, sans-serif; line-height: 1.5;">
        <h1 style="margin: 0 0 0.75rem;">Symfony Web Template</h1>
        <p style="margin: 0 0 1.25rem; color: #4b5563;">A reusable Symfony starter with Docker, Make targets, and AI tooling integration.</p>

        <section>
            <h2 style="font-size: 1.1rem; margin: 0 0 0.5rem;">Included</h2>
            <ul style="margin: 0; padding-left: 1.25rem;">
                <li>FrankenPHP-based local runtime</li>
                <li>AssetMapper + Tailwind setup</li>
                <li>Template-ready docs and agent prompts</li>
            </ul>
        </section>
    </main>
{% endblock %}
